# ─── Firebase (client SDK — safe to expose in browser) ──────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ─── Firebase Admin SDK (server-side only — NEVER expose in browser) ─────────
# Used by seed-firestore.ts and any server-side admin operations
FIREBASE_ADMIN_PROJECT_ID=your_firebase_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Alternative: path to service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ─── Anthropic / Claude API ──────────────────────────────────────────────────
# Used by /api/recommend and /api/redirect (Agentic AI features)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google AI / Genkit ──────────────────────────────────────────────────────
# Used by the Genkit AI flow (ai-powered-queue-recommendation)
GOOGLE_GENAI_API_KEY=your_google_ai_api_key

# ─── App Base URL (used by WhatsApp payment links) ──────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ─── Twilio WhatsApp API ─────────────────────────────────────────────────────
# Get from: https://console.twilio.com
# Sandbox number: whatsapp:+14155238886 (Twilio sandbox — no approval needed for testing)
# Production: use your approved WhatsApp Business number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── PayFast (South African payment gateway) ────────────────────────────────
# Sandbox: merchant_id=10000100, merchant_key=test (no signup needed for testing)
# Live: https://www.payfast.co.za/registration
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=test
PAYFAST_PASSPHRASE=

# Configure in Twilio Console → Messaging → WhatsApp → Sandbox → "When a message comes in":
# POST https://your-domain.com/api/whatsapp/webhook
#
# Configure in PayFast:
# Notify URL: https://your-domain.com/api/whatsapp/payment-confirm
