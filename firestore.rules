rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — authenticated users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Branches — public read; writes are done server-side via Admin SDK
    match /branches/{branchId} {
      allow read: if true;
      allow write: if true;   // demo: seed + consultant writes
    }

    // Queue sessions — public read; admin SDK handles writes
    match /queueSessions/{sessionId} {
      allow read: if true;
      allow write: if true;
    }

    // Queue tickets — public read (ticketId is long & unguessable)
    match /queueTickets/{ticketId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /analytics/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /predictions/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /notifications/{docId} {
      allow read, write: if false;
    }
  }
}
