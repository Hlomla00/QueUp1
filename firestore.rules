rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own profile document only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Branches are publicly readable; writes are server-side only (Admin SDK)
    match /branches/{branchId} {
      allow read: if true;
      allow write: if false;
    }

    // Queue tickets — authenticated users can read and create
    match /queueTickets/{ticketId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Analytics and predictions — authenticated read, server-only write
    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /predictions/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Notifications — server-only
    match /notifications/{docId} {
      allow read, write: if false;
    }
  }
}
